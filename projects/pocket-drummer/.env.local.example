# =========================================================================
# Pocket Drummer Environment Variables Template
# Copy this file to '.env.local' and replace with your actual keys.
# =========================================================================

# 1. DeepSeek API Key (Server-Side)
# Required for generating MusicXML sheet music and learning plans.
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 2. Gemini API Key (Server-Side)
# Required for scanning PDF/image sheet music (OMR) using gemini-2.5-flash.
# Obtain a key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 3. Firebase Client Config (Publicly exposed to the client bundle)
# Get these credentials from: Firebase Console → Project Settings → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyBUl-rEtOI7lizp3929lJiiQxcrAqjKJbE
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=gen-lang-client-0782413722.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=gen-lang-client-0782413722
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=gen-lang-client-0782413722.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1039047861584
NEXT_PUBLIC_FIREBASE_APP_ID=1:1039047861584:web:cec2375439fcf3bdda7855
