rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profiles: Open read/write during mock testing phase
    match /users/{email} {
      allow read, write: if true;
    }
    
    // Learning Plans: Open read/write during mock testing phase
    match /learningPlans/{email} {
      allow read, write: if true;
    }
    
    // Exercises: Globally readable by everyone, editable only by system admins (none by default)
    match /exercises/{exerciseId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
