# =========================================================================
# Pocket Drummer Environment Variables Template
# Copy this file to '.env.local' and replace with your actual keys.
# =========================================================================

# 1. DeepSeek API Key (Server-Side)
# Required for generating MusicXML sheet music and learning plans.
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 2. Gemini API Key (Server-Side)
# Required for scanning PDF/image sheet music (OMR) using gemini-2.5-flash.
# Obtain a key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Firebase Client Config (Publicly exposed to the client bundle)
# Get these credentials from your Firebase Console (Project Settings -> General -> Your apps -> Web app)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=pocket-drummer-2026.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=pocket-drummer-2026
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=pocket-drummer-2026.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
