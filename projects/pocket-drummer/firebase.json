{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "site": "drumlab",
    "source": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "frameworksBackend": {
      "region": "us-central1",
      "framework": "nextjs",
      "secrets": ["DEEPSEEK_API_KEY", "GEMINI_API_KEY"]
    }
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
