{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "site": "pocket-drummer",
    "source": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      ".firebase/**",
      "functions/**",
      "docs/**",
      "*.md",
      "*.txt",
      "*.rtf",
      "firebase-debug.log"
    ],
    "frameworksBackend": {
      "region": "us-central1",
      "secrets": ["DEEPSEEK_API_KEY", "GEMINI_API_KEY"]
    }
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
